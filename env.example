APP_NAME=v4-agentic-trader
ADMIN_TOKEN=replace-with-a-long-random-token

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_DATA_FEED=iex

# Optional. Without this, v4 still accepts direct commands through regex/rules.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

DEFAULT_ORDER_QTY=1
DEFAULT_TIME_IN_FORCE=day
EXTENDED_HOURS=false
MAX_UPLOAD_MB=10
DATA_DIR=./data

# Autonomous paper-trading loop. Starts as dry-run by default.
AUTONOMY_ENABLED=false
AUTONOMY_DRY_RUN=true
AUTONOMY_INTERVAL_SECONDS=900
AUTONOMY_SYMBOLS=SPY,QQQ,IWM,AAPL,MSFT,NVDA,AMD,TSLA,META,GOOGL,AMZN,PLTR,SOFI,COIN,HOOD
AUTONOMY_MIN_SCORE=65
AUTONOMY_MAX_ORDERS_PER_CYCLE=1
AUTONOMY_MAX_POSITIONS=5
