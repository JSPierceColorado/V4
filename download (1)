def test_dsl_entry_signal_evaluates_ai_rules() -> None:
    closes = [10.0] * 80 + [9.8, 9.7, 9.6, 9.5, 9.4, 10.2]
    volumes = [100000.0] * len(closes)
    strategy = {
        "score_bias": 0,
        "min_entry_score": 0,
        "entry_logic": "all",
        "entry_rules": [
            {"metric": "ret_5d_pct", "op": ">", "value": 1},
            {"metric": "close", "op": ">", "value": 10},
        ],
    }

    should_enter, score = _entry_signal(strategy, closes, volumes, len(closes) - 1)

    assert should_enter is True
    assert score >= 0
