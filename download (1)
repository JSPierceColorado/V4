def test_ai_triage_selects_variant_subset(monkeypatch, tmp_path) -> None:
    monkeypatch.setenv("DATA_DIR", str(tmp_path))
    monkeypatch.setenv("OPENAI_API_KEY", "test-key")
    monkeypatch.setenv("AUTONOMY_AI_VARIANT_TRIAGE_TARGET", "4")
    settings = load_settings()

    class FakeResponses:
        def create(self, **kwargs):
            return SimpleNamespace(
                output_text='{"selected_ids":["v5","v3","v1","v4"],"rationale":"diverse"}'
            )

    class FakeOpenAI:
        def __init__(self, api_key):
            self.responses = FakeResponses()

    monkeypatch.setitem(sys.modules, "openai", SimpleNamespace(OpenAI=FakeOpenAI))
    variants = [
        {
            "id": f"v{index}",
            "source": "research",
            "family": "momentum",
            "take_profit_pct": 0.02,
            "stop_loss_pct": -0.01,
            "max_hold_days": 5,
            "min_entry_score": 20,
            "score_bias": 0,
        }
        for index in range(1, 8)
    ]

    selected, triage = ai_triage_variants(
        settings,
        {"research_history": []},
        {"AAA": _bars()},
        variants,
    )

    assert triage["used"] is True
    assert triage["selected_variants"] == 4
    assert [variant["id"] for variant in selected] == ["v5", "v3", "v1", "v4"]


def test_ai_triage_falls_back_to_target_when_model_returns_bad_ids(monkeypatch, tmp_path) -> None:
    monkeypatch.setenv("DATA_DIR", str(tmp_path))
    monkeypatch.setenv("OPENAI_API_KEY", "test-key")
    monkeypatch.setenv("AUTONOMY_AI_VARIANT_TRIAGE_TARGET", "4")
    settings = load_settings()

    class FakeResponses:
        def create(self, **kwargs):
            return SimpleNamespace(
                output_text='{"selected_ids":["missing-1"],"rationale":"bad"}'
            )

    class FakeOpenAI:
        def __init__(self, api_key):
            self.responses = FakeResponses()

    monkeypatch.setitem(sys.modules, "openai", SimpleNamespace(OpenAI=FakeOpenAI))
    variants = [
        {
            "id": f"v{index}",
            "source": "mutation" if index % 2 else "research",
            "family": "momentum" if index % 3 else "breakout",
            "take_profit_pct": 0.02,
            "stop_loss_pct": -0.01,
            "max_hold_days": 5,
            "min_entry_score": 20,
            "score_bias": 0,
        }
        for index in range(1, 9)
    ]

    selected, triage = ai_triage_variants(
        settings,
        {"research_history": []},
        {"AAA": _bars()},
        variants,
    )

    assert triage["used"] is False
    assert triage["reason"] == "too_few_valid_ids_deterministic_fallback"
    assert triage["selected_variants"] == 4
    assert len(selected) == 4


