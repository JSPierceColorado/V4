def test_mutation_variants_descend_from_recent_research_parent() -> None:
    parent = {
        "id": "research_parent_tp40",
        "label": "Parent strategy",
        "family": "momentum",
        "score_bias": 0,
        "min_entry_score": 40,
        "take_profit_pct": 0.04,
        "stop_loss_pct": -0.025,
        "max_hold_days": 20,
        "stats": {},
    }
    variants = generate_mutation_variants(
        {
            "last_research": {
                "top": [{"strategy": parent, "combined_fitness": -0.001}],
            },
            "research_history": [{"researched_at": "now"}],
            "strategies": {},
        },
        max_variants=12,
        parent_count=1,
    )

    assert len(variants) == 12
    assert {variant["source"] for variant in variants} == {"mutation"}
    assert {variant["parent_strategy_id"] for variant in variants} == {"research_parent_tp40"}
    assert any(variant["take_profit_pct"] != parent["take_profit_pct"] for variant in variants)


